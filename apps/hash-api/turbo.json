{
  "extends": ["//"],
  "tasks": {
    "codegen": {
      // Outputs of GraphQL generation
      "outputs": ["./src/**/*.gen.*"],
      // The optimizer handler imports runtime modules whose workspace exports
      // resolve from dist.
      "dependsOn": [
        "^codegen",
        "@hashintel/petrinaut-core#build",
        "@local/petrinaut-optimizer-client#build"
      ]
    }
  }
}
